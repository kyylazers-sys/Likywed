*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Poppins',sans-serif;
background:#f8f3eb;
color:#44392d;
overflow-x:hidden;
}

section{
padding:100px 80px;
position:relative;
overflow:hidden;
}
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: hidden;
}

/* FRAME GARIS */
.hero-frame {
  position: relative;
  width: 90%;
  max-width: 420px;
  padding: 30px 20px;

  border: 1px solid rgba(255,255,255,0.25);
  border-radius: 20px;

  background: transparent;
}

/* CONTENT */
.hero-content {
  text-align: center;
}

/* TITLE */
.hero-mini {
  letter-spacing: 3px;
  font-size: 12px;
  margin-bottom: 20px;
  opacity: 0.8;
}

/* MONOGRAM */
.hero-monogram {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  margin-bottom: 20px;
}

.hero-monogram h1 {
  font-size: 55px;
  font-weight: 600;
}

.hero-line {
  width: 45px;
  height: 1px;
  background: rgba(255,255,255,0.5);
}

/* NAMA */
.hero-content h2 {
  font-size: 28px;
  line-height: 1.5;
  font-weight: 500;
}

.hero-content h2 span {
  display: block;
  font-size: 18px;
  margin: 8px 0;
}

/* DATE */
.hero-date {
  margin-top: 18px;
  letter-spacing: 2px;
  font-size: 13px;
  opacity: 0.85;
}

/* BUNGA */
.hero-flower {
  position: absolute;
}

/* OPTIONAL CORNER FRAME */
.hero-frame::before,
.hero-frame::after {
  content: "";
  position: absolute;
  width: 40px;
  height: 40px;
  border-color: rgba(255,255,255,0.35);
}

.hero-frame::before {
  top: 10px;
  left: 10px;
  border-top: 1px solid;
  border-left: 1px solid;
}

.hero-frame::after {
  bottom: 10px;
  right: 10px;
  border-bottom: 1px solid;
  border-right: 1px solid;
}

.event-space{
  height: 35px;
}

.event-card h2:nth-of-type(2){
  margin-top: 35px;
}

.sharelock-map{
  position: relative;
  display: block;
  width: 100%;
  margin-top: 25px;
  border-radius: 24px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.15);
  box-shadow: 0 10px 30px rgba(0,0,0,0.25);
}

.sharelock-map img{
  width: 100%;
  height: 220px;
  object-fit: cover;
  display: block;
  transition: 0.4s ease;
}

.sharelock-map:hover img{
  transform: scale(1.05);
}

.map-overlay{
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(0,0,0,0.75),
    rgba(0,0,0,0.15)
  );
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 18px;
}

.map-overlay span{
  color: white;
  font-size: 15px;
  letter-spacing: 1px;
  padding: 10px 20px;
  border-radius: 50px;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.2);
}

.opening{
position:fixed;
inset:0;
background:
linear-gradient(rgba(255,255,255,.65),rgba(255,255,255,.65)),
url('assets/images/texture.jpg');
background-size:cover;
display:flex;
justify-content:center;
align-items:center;
z-index:9999;
transition:1s;
overflow:hidden;
}
.opening-overlay{
position:absolute;
inset:0;
backdrop-filter:blur(3px);
}

.flower{
position:absolute;
width:620px;
height:620px;
background-image:url('assets/images/floral.png');
background-size:contain;
background-repeat:no-repeat;
animation:float 6s ease-in-out infinite;
opacity:.9;
}

.flower-top-left{
top:-30px;
left:-20px;
}

.flower-top-right{
top:-30px;
right:-20px;
transform:scaleX(-1);
}

.flower-bottom-left{
bottom:-40px;
left:-20px;
transform:rotate(180deg);
}

.flower-bottom-right{
bottom:-40px;
right:-20px;
transform:rotate(180deg) scaleX(-1);
}

.opening-content{
position:relative;
z-index:5;
position:relative;
z-index:2;
text-align:center;
max-width:700px;
}

.small-title{
letter-spacing:8px;
font-size:13px;
margin-bottom:25px;
}

.monogram-wrap{
display:flex;
align-items:center;
justify-content:center;
gap:20px;
}

.line{
width:90px;
height:1px;
background:#b79667;
}

.opening h1,
.hero h1{
font-family:'Cormorant Garamond',serif;
font-size:150px;
color:#b79667;
font-weight:500;
line-height:1;
}

.opening h2,
.hero h2{
font-family:'Great Vibes',cursive;
font-size:70px;
font-weight:400;
margin-top:10px;
color:#7a6140;
}

.opening h2 span,
.hero h2 span{
display:block;
font-size:45px;
margin:5px 0;
}

.date-text,
.hero-date{
margin-top:24px;
letter-spacing:5px;
font-size:14px;
}

.guest-box{
margin-top:60px;
}

.guest-box h3{
margin-top:12px;
font-size:28px;
}

button{
padding:16px 40px;
border:none;
border-radius:999px;
background:#b79667;
color:white;
font-size:15px;
margin-top:35px;
cursor:pointer;
transition:.3s;
box-shadow:0 10px 25px rgba(183,150,103,.3);
}

button:hover{
transform:translateY(-4px);
}

.hero{
min-height:100vh;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
background:#f8f3eb;
overflow:hidden;
}

.texture{
position:absolute;
inset:0;
background:url('assets/images/bg.jpg');
background-size:cover;
opacity:.2;
}

.hero-flower{
position:absolute;
width:720px;
height:720px;
background:url('assets/images/floral.png');
background-size:contain;
background-repeat:no-repeat;
opacity:.6;
}

.hero-flower.left{
left:-60px;
bottom:-50px;
}

.hero-flower.right{
right:-60px;
top:-30px;
transform:scaleX(-1);
}

.hero-content{
position:relative;
z-index:5;
position:relative;
z-index:2;
}

.hero-mini{
letter-spacing:8px;
font-size:13px;
margin-bottom:25px;
}

.quote-section,
.story-section,
.countdown-section,
.event-section,
.gallery-section,
.wish-section{
text-align:center;
}

.quote-section h1,
.story-section h1,
.countdown-section h1,
.event-section h1,
.gallery-section h1,
.wish-section h1{
font-family:'Cormorant Garamond',serif;
font-size:60px;
margin-bottom:30px;
color:#b79667;
}

.section-line{
position:absolute;
top:0;
width:90px;
height:100%;
background-image:url('assets/images/ornament.png');
background-size:contain;
background-repeat:repeat-y;
background-position:center;
opacity:.35;
z-index:1;
background:linear-gradient(to bottom,transparent,#d7bb8e,transparent);
opacity:.7;
}

.left-line{
left:0;
transform:translateY(-50%);
}

.right-line{
right:0;
transform:translateY(-50%);
}

.story-wrap{
max-width:900px;
margin:50px auto 0;
display:flex;
flex-direction:column;
gap:25px;
}

.story-item{
background:white;
padding:35px;
border-radius:30px;
border:1px solid #ecdab8;
box-shadow:0 10px 30px rgba(0,0,0,.04);
text-align:left;
position:relative;
}

.story-item span{
font-size:42px;
font-family:'Cormorant Garamond',serif;
color:#b79667;
font-weight:700;
}

.story-item h2{
margin-top:10px;
font-size:32px;
font-family:'Cormorant Garamond',serif;
}

.story-item p{
margin-top:15px;
line-height:1.9;
}

.quote-section,
.story-section,
.countdown-section,
.event-section,
.gallery-section,
.wish-section,
.couple-section{
position:relative;
z-index:2;
}

.quote-section p{
max-width:750px;
margin:auto;
line-height:2.2;
}

.section-ornament{
width:140px;
height:40px;
margin:0 auto 30px;
background:url('assets/images/ornament.png');
background-size:contain;
background-repeat:no-repeat;
background-position:center;
}

.couple-section{
display:flex;
justify-content:center;
align-items:center;
gap:35px;
flex-wrap:wrap;
background:white;
}

.couple-card{
width:340px;
padding:45px 30px;
background:#fffaf4;
border:1px solid #ecdab8;
border-radius:40px;
box-shadow:0 15px 35px rgba(0,0,0,.04);
}

.couple-card h2{
font-family:'Great Vibes',cursive;
font-size:62px;
color:#b79667;
}

.couple-card h3{
font-family:'Cormorant Garamond',serif;
font-size:40px;
margin-top:10px;
}

.couple-card p{
margin-top:18px;
line-height:1.9;
}

.heart{
font-size:55px;
color:#b79667;
animation:pulse 1.6s infinite;
}

#countdown{
font-size:38px;
font-weight:600;
}

.event-container {
  display: flex;
  justify-content: center;
}

.event-card.single-event {
  max-width: 500px;
  padding: 25px;
  border-radius: 16px;
  background: rgba(255,255,255,0.08);
  backdrop-filter: blur(10px);
  text-align: center;
  box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

.event-card .event-location {
  display: block;
  margin-top: 12px;
  font-size: 13px;
  opacity: 0.85;
  line-height: 1.6;
}

.countdown-wrapper {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

.time-box {
  width: 80px;
  height: 90px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(8px);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}

.time-number {
  font-size: 22px;
  font-weight: bold;
}

.time-label {
  font-size: 12px;
  opacity: 0.8;
  margin-top: 4px;
}

.gallery-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
max-width:1000px;
margin:50px auto 0;
}

.gift-row button {
  margin-top: 8px;
  padding: 6px 10px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  background: white;
  color: black;
  font-size: 12px;
}

.gift-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  justify-content: center;
  align-items: center;
  z-index: 999;
}

/* INI CARD UTAMA DI DALAM MODAL */
.gift-modal {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.5);
  justify-content: center;
  align-items: center;
  z-index: 999;
}

/* CARD KECIL */
.gift-card-modal.small {
  width: 85%;
  max-width: 280px;   /* diperkecil biar aman */
  padding: 12px;      /* dikurangi */
  border-radius: 14px;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(12px);
  text-align: center;
  overflow: hidden;   /* biar gak “bleeding” keluar */
}

/* tiap item lebih compact */
.gift-row {
  padding: 8px;
  margin: 6px 0;
  border-radius: 10px;
  background: rgba(255,255,255,0.08);
}

/* nomor biar gak terlalu besar */
.gift-row p {
  margin: 3px 0;
  font-size: 13px;   /* penting: kecilin */
  font-weight: 600;
}

/* nama lebih kecil */
.gift-row small {
  font-size: 10px;
  opacity: 0.8;
}

/* tombol lebih kecil juga */
.gift-row button {
  margin-top: 6px;
  padding: 5px 8px;
  font-size: 11px;
  border-radius: 7px;
}

/* BUTTON GLOBAL COPY */
.copy-all {
  margin-top: 10px;
  width: 100%;
  padding: 10px;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  background: white;
  color: black;
}

.close-btn {
  margin-top: 8px;
  width: 100%;
  padding: 10px;
  border-radius: 10px;
  border: none;
  cursor: pointer;
  background: rgba(255,255,255,0.2);
  color: white;
}

.quote-section {
  position: relative;
  padding: 60px 20px;
  display: flex;
  justify-content: center;
}

.quote-card {
  max-width: 700px;
  padding: 30px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
  text-align: center;
  position: relative;
  box-shadow: 0 10px 30px rgba(0,0,0,0.2);
}

.quote-card h2 {
  margin-bottom: 15px;
  font-size: 22px;
  letter-spacing: 1px;
}

.quote-card .arabic {
  font-size: 20px;
  line-height: 2;
  direction: rtl;
  margin-bottom: 15px;
}

.quote-card .translation {
  font-size: 14px;
  opacity: 0.85;
  line-height: 1.6;
}

/* garis kiri kanan */
.section-line {
  position: absolute;
  top: 20px;
  width: 60px;
  height: 2px;
  background: #fff;
  opacity: 0.4;
}

.left-line {
  left: 20px;
}

.right-line {
  right: 20px;
}

.gallery-item{
height:320px;
border-radius:30px;
background:
linear-gradient(rgba(255,255,255,.2),rgba(255,255,255,.2)),
url('assets/images/bg.jpg');
background-size:cover;
box-shadow:0 10px 25px rgba(0,0,0,.05);
}

form{
max-width:700px;
margin:40px auto 0;
background:white;
padding:35px;
border-radius:35px;
border:1px solid #ecdab8;
display:flex;
flex-direction:column;
gap:20px;
}

input,
select,
textarea{
padding:18px;
border-radius:20px;
border:1px solid #ddd;
font-size:15px;
font-family:'Poppins',sans-serif;
}

textarea{
height:140px;
resize:none;
}

.comment-list{
max-width:700px;
margin:40px auto 0;
display:flex;
flex-direction:column;
gap:20px;
}

.comment-item{
background:white;
padding:25px;
border-radius:25px;
text-align:left;
border:1px solid #ecdab8;
animation:fadeUp .5s ease;
}

.comment-info{
display:block;
font-size:13px;
margin-bottom:12px;
opacity:.7;
}

.comment-item h3{
margin-bottom:10px;
color:#7a6140;
}

footer{
padding:80px 20px;
text-align:center;
}

footer h2{
font-family:'Great Vibes',cursive;
font-size:65px;
color:#b79667;
}

.music-btn{
position:fixed;
right:20px;
bottom:20px;
width:60px;
height:60px;
border-radius:50%;
background:#b79667;
color:white;
display:flex;
justify-content:center;
align-items:center;
font-size:24px;
z-index:999;
cursor:pointer;
box-shadow:0 10px 30px rgba(183,150,103,.35);
animation:rotate 5s linear infinite;
}

@keyframes float{
0%{transform:translateY(0px);}
50%{transform:translateY(-15px);}
100%{transform:translateY(0px);}
}

@keyframes pulse{
0%{transform:scale(1);}
50%{transform:scale(1.12);}
100%{transform:scale(1);}
}

@keyframes rotate{
100%{transform:rotate(360deg);}
}

.reveal{
opacity:0;
transform:scale(.8) translateY(40px);
transition:1s ease;
}

.reveal.active{
opacity:1;
transform:scale(1) translateY(0);
}

@keyframes fadeUp{
from{
opacity:0;
transform:translateY(20px);
}

to{
opacity:1;
transform:translateY(0);
}
}

html{
scroll-behavior:smooth;
}

@media(max-width:768px){

section{
padding:90px 24px;
}

.flower{
width:320px;
height:320px;
}

.hero-flower{
width:380px;
height:380px;
}


.section-line{
display:none;
}

.story-item span{
font-size:34px;
}

.story-item h2{
font-size:28px;
}


.opening h1,
.hero h1{
font-size:100px;
}

.opening h2,
.hero h2{
font-size:48px;
}

.quote-section h1,
.countdown-section h1,
.event-section h1,
.gallery-section h1,
.wish-section h1{
font-size:45px;
}

#countdown{
font-size:24px;
}

.flower,
.hero-flower{
width:190px;
height:190px;
}

}